# Azure OpenAI configuration for the "Azure OpenAI (AI-assisted)" generation engine.
#
# Copy this file to `.env.local` (which is gitignored) and fill in real values.
# Do NOT put real keys in this file — `.env.example` is committed to git.
#
# ⚠️ These VITE_-prefixed vars are bundled into the client JavaScript at build
# time and are visible to anyone who opens the running app. This is fine for
# LOCAL, PERSONAL use only. Never deploy this build publicly with a real key —
# that would require a server-side proxy to keep the key secret.

# Resource endpoint, e.g. https://my-resource.openai.azure.com
VITE_AZURE_OPENAI_ENDPOINT=

# The API key for the Azure OpenAI resource.
VITE_AZURE_OPENAI_KEY=

# The deployment (model) name configured in your Azure resource.
VITE_AZURE_OPENAI_DEPLOYMENT=

# REST API version (optional; defaults to 2024-10-21 if omitted).
VITE_AZURE_OPENAI_API_VERSION=2024-10-21
